{
  "name": "cargill",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android --mode=cargillDebug",
    "android:dev": "ENVFILE=.env.development react-native run-android --mode=cargillDebug",
    "android:qa": "ENVFILE=.env.qa react-native run-android --mode=cargillDebug",
    "android:staging": "ENVFILE=.env.UAT react-native run-android --mode=cargillDebug",
    "android:prod": "ENVFILE=.env.prod react-native run-android --mode=prodDebug",
    "android:internalProd": "ENVFILE=.env.internalProd react-native run-android --mode=cargillDebug",
    "ios": "react-native run-ios",
    "ios:dev": "react-native run-ios --scheme cargill_dev",
    "ios:qa": "react-native run-ios --scheme cargill_QA",
    "ios:staging": "react-native run-ios --scheme cargill_staging",
    "ios:prod": "react-native run-ios --scheme cargill",
    "ios:internalProd": "react-native run-ios --scheme cargill_internal_prod",
    "start": "react-native start --reset-cache",
    "test": "jest",
    "lint": "eslint .",
    "clean-android": "cd android/ && ./gradlew clean && cd ..",
    "clean-pods": "cd ios/ && rm -rf Podfile.lock Pods",
    "update-android-bundle": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res && sh rmbuildf.sh",
    "update-ios-bundle": "react-native bundle --entry-file index.js --platform ios --dev false --bundle-output ios/main.jsbundle --assets-dest ios",
    "build-android": "cd android && ./gradlew assembleCargillDebug",
    "build-android-release": "cd android && ./gradlew assembleCargillRelease",
    "build-android-release-dev": "cd android && ENVFILE=.env.development ./gradlew assembleCargillRelease",
    "build-android-release-qa": "cd android && ENVFILE=.env.qa ./gradlew assembleCargillRelease",
    "build-android-release-staging": "cd android && ENVFILE=.env.UAT ./gradlew assembleCargillRelease",
    "build-android-release-prod": "cd android && ENVFILE=.env.prod ./gradlew assembleProdRelease",
    "build-android-release-internalProd": "cd android && ENVFILE=.env.internalProd ./gradlew assembleInternalProdRelease",
    "release-prod": "cd android && ./gradlew bundle",
    "rebuild": "rm -rf node_modules yarn.lock && yarn"
  },
